from flask import Blueprint
from flask_jwt_extended import jwt_required
from app.core.extensions import limiter
from .controllers import AuthController
{% for model in models %}
from .controllers import {{ model.name }}Controller
{% endfor %}

api_bp = Blueprint('api', __name__)

# Auth Routes
@api_bp.route('/auth/register', methods=['POST'])
@limiter.limit("5 per minute")
def register():
    return AuthController.register()

@api_bp.route('/auth/login', methods=['POST'])
@limiter.limit("10 per minute")
def login():
    return AuthController.login()

@api_bp.route('/auth/refresh', methods=['POST'])
@jwt_required(refresh=True)
def refresh():
    return AuthController.refresh()

@api_bp.route('/auth/me', methods=['GET'])
@jwt_required()
def me():
    return AuthController.get_me()

{% for model in models %}
# {{ model.name }} CRUD Routes
@api_bp.route('/{{ model.name.lower() }}s', methods=['GET'])
@jwt_required()
def get_{{ model.name.lower() }}s():
    return {{ model.name }}Controller.get_all()

@api_bp.route('/{{ model.name.lower() }}s/<int:id>', methods=['GET'])
@jwt_required()
def get_{{ model.name.lower() }}(id):
    return {{ model.name }}Controller.get_by_id(id)

@api_bp.route('/{{ model.name.lower() }}s', methods=['POST'])
@jwt_required()
def create_{{ model.name.lower() }}():
    return {{ model.name }}Controller.create()

@api_bp.route('/{{ model.name.lower() }}s/<int:id>', methods=['PUT'])
@jwt_required()
def update_{{ model.name.lower() }}(id):
    return {{ model.name }}Controller.update(id)

@api_bp.route('/{{ model.name.lower() }}s/<int:id>', methods=['DELETE'])
@jwt_required()
def delete_{{ model.name.lower() }}(id):
    return {{ model.name }}Controller.delete(id)
{% endfor %}
